# FreeAgent API Credentials
# Register your app at https://dev.freeagent.com to get these
FREEAGENT_CLIENT_ID=your_oauth_identifier
FREEAGENT_CLIENT_SECRET=your_oauth_secret

# The callback URL registered with FreeAgent (must match exactly)
FREEAGENT_REDIRECT_URI=http://localhost:3000/api/freeagent/callback

# Your app's base URL
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Set to 'true' to use the FreeAgent sandbox environment for testing
# FREEAGENT_SANDBOX=true
